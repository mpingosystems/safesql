# Copy to .env.local and fill in. .env.local is gitignored (matches *.local).
# VITE_* vars are inlined into the public JS bundle at build time.
# Server-only secrets (no VITE_ prefix) are read by `wrangler pages dev` for
# local Functions testing only — for the deployed Functions, set them via
# `wrangler pages secret put NAME --project-name safesql` or in the
# Cloudflare Pages dashboard.

# ── Anthropic (AI explanation layer) ─────────────────────────────────────────
# Browser-direct API call uses anthropic-dangerous-direct-browser-access.
# Set spending caps in the Anthropic dashboard. Eventually should be proxied
# through a Function so the key isn't bundled.
VITE_ANTHROPIC_API_KEY=
VITE_AI_PROVIDER=claude

# ── Clerk (auth) ─────────────────────────────────────────────────────────────
# Use VITE_ prefix, NOT NEXT_PUBLIC_ — this is Vite, not Next.js.
VITE_CLERK_PUBLISHABLE_KEY=

# ── Supabase (persistence) ───────────────────────────────────────────────────
# Frontend uses anon key + Clerk JWT for RLS-scoped access.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only — read by wrangler pages dev. Production Functions read these
# from Pages secrets, not this file.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Publishable key (browser-safe).
VITE_STRIPE_PUBLISHABLE_KEY=

# Per-plan, per-cadence price IDs from Stripe dashboard.
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=
VITE_STRIPE_TEAM_MONTHLY_PRICE_ID=
VITE_STRIPE_TEAM_ANNUAL_PRICE_ID=
VITE_STRIPE_BUSINESS_MONTHLY_PRICE_ID=
VITE_STRIPE_BUSINESS_ANNUAL_PRICE_ID=

# Optional: base origin for first-party /api/* calls (checkout, portal).
# Leave unset for same-origin. Set to the canonical Pages origin to bypass a
# broken custom-domain edge, e.g. VITE_API_BASE_URL=https://safesql.pages.dev
VITE_API_BASE_URL=

# Server-only — production reads these from Pages secrets.
# STRIPE_SECRET_KEY (sk_test_... or sk_live_...)
# STRIPE_WEBHOOK_SECRET (whsec_...)
# STRIPE_PRO_PRICE_IDS (comma-sep, monthly+annual)
# STRIPE_TEAM_PRICE_IDS
# STRIPE_BUSINESS_PRICE_IDS

# ── Site ─────────────────────────────────────────────────────────────────────
# Used by /api/checkout to build Stripe success/cancel URLs.
# Defaults to https://safesql.dev when unset.
SITE_URL=https://safesql.pages.dev

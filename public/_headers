# Cloudflare Pages cache rules.
#
# index.html must never be cached hard: every deploy rewrites the hashed asset
# references inside it. If a browser serves a stale index.html it will request
# chunk hashes that no longer exist on the server, producing
# "Failed to fetch dynamically imported module" (e.g. the lazy PGlite chunk).
/index.html
  Cache-Control: no-cache, must-revalidate

/
  Cache-Control: no-cache, must-revalidate

# Hashed build assets are content-addressed and safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

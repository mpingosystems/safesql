# Copy this file to .env.local and fill in real values.
# .env.local is gitignored (matches *.local in .gitignore).

# Anthropic — drives the AI explanation layer (rules detect, AI explains).
# Browser-direct API access uses anthropic-dangerous-direct-browser-access header.
# In production, proxy through a Worker rather than exposing the key.
VITE_ANTHROPIC_API_KEY=
VITE_AI_PROVIDER=claude

# Stripe — publishable key only. Secret key never goes here.
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe price IDs — get from Stripe dashboard > Products after creating prices.
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=
VITE_STRIPE_TEAM_MONTHLY_PRICE_ID=
VITE_STRIPE_TEAM_ANNUAL_PRICE_ID=
VITE_STRIPE_BUSINESS_MONTHLY_PRICE_ID=
VITE_STRIPE_BUSINESS_ANNUAL_PRICE_ID=

# Backend endpoint that creates a Stripe Checkout Session and returns its URL.
# Implemented in Sprint 2 as a Cloudflare Worker.
VITE_CHECKOUT_ENDPOINT=/api/checkout

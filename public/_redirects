# Canonical-domain 301: any link to the old safesql.realitydb.dev host (Slack
# shares, blog posts, old permalinks) redirects to safesqlpro.dev. Host-qualified,
# so safesqlpro.dev and *.pages.dev preview deploys are unaffected.
https://safesql.realitydb.dev/*  https://safesqlpro.dev/:splat  301

# SPA fallback for the short-URL permalink path (/v/{id}). Real files (assets,
# favicon) are served first; /api/* is handled by Pages Functions via
# _routes.json. Only unmatched /v/* paths fall through to index.html so the
# React app can read the id and fetch the shared validation.
/v/*  /index.html  200
